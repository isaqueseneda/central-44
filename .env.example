# Database (Neon Cloud PostgreSQL)
# Get this from: https://console.neon.tech/app/projects
DATABASE_URL="postgresql://neondb_owner:xxxxx@ep-xxxxx.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Google OAuth2 (for Drive access)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_PROJECT_ID="your-google-project-id"

# Google Maps API
# Get from: https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# OpenRouter API (for AI sidebar agent)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-xxxxx"

# TollGuru API (for toll calculation)
# Get your key at: https://tollguru.com
TOLLGURU_API_KEY=""

# Optional: Notion API (only needed for initial migration)
NOTION_API_KEY=""
NOTION_DB_OS=""
NOTION_DB_LOJAS=""
NOTION_DB_FUNCIONARIOS=""
NOTION_DB_FROTA=""
NOTION_DB_SERVICOS=""
NOTION_DB_MATERIAIS=""
